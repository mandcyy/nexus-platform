generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  username      String?   @unique
  email         String?   @unique
  phone         String?   @unique
  passwordHash  String
  displayName   String
  avatarUrl     String?
  bio           String?
  status        String    @default("OFFLINE")
  lastSeen      DateTime?
  isVerified    Boolean   @default(false)
  isPremium     Boolean   @default(false)
  role          String    @default("USER")
  level         Int       @default(1)
  xp            BigInt    @default(0)
  reputation    Int       @default(0)
  totpSecret    String?
  totpEnabled   Boolean   @default(false)
  otpEnabled    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions       Session[]
  devices        Device[]
  recoveryCodes  RecoveryCode[]
  keyBundle      KeyBundle?
  followers      Follow[]  @relation("Following")
  following      Follow[]  @relation("Follower")
  sentMessages   Message[] @relation("Sender")
  reactions      Reaction[]

  @@index([username])
  @@index([email])
  @@index([phone])
  @@index([displayName])
}

model Session {
  id         String    @id
  userId     String
  deviceId   String?
  ipAddress  String?
  userAgent  String?
  isRevoked  Boolean   @default(false)
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime

  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRevoked])
}

model Device {
  id          String    @id
  userId      String
  deviceId    String
  deviceName  String
  osVersion   String?
  appVersion  String?
  fingerprint String?
  pushToken   String?
  isTrusted   Boolean   @default(true)
  isRevoked   Boolean   @default(false)
  firstSeen   DateTime  @default(now())
  lastActive  DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([deviceId])
  @@unique([userId, deviceId])
}

model RecoveryCode {
  id      String    @id
  userId  String
  code    String
  isUsed  Boolean   @default(false)
  usedAt  DateTime?

  user    User      @relation(fields: [userId], references: [id])

  @@index([userId, isUsed])
}

model KeyBundle {
  id               String  @id
  userId           String  @unique
  identityKey      String
  signedPreKey     String
  signedPreKeyId   Int
  registrationId   Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User    @relation(fields: [userId], references: [id])
}

model OneTimePreKey {
  id        String    @id
  userId    String
  keyId     Int
  publicKey String
  isUsed    Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId, isUsed])
}

model Follow {
  id          String    @id
  followerId  String
  followingId String
  createdAt   DateTime  @default(now())

  follower    User      @relation("Follower", fields: [followerId], references: [id])
  following   User      @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Message {
  id               String    @id
  chatId           String
  senderId         String
  contentType      String
  contentJson      String
  status           String    @default("SENT")
  replyTo          String?
  forwardFromJson  String?
  isEdited         Boolean   @default(false)
  editedAt         DateTime?
  isPinned         Boolean   @default(false)
  isStarred        Boolean   @default(false)
  selfDestructAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime?

  sender           User      @relation("Sender", fields: [senderId], references: [id])
  reactions        Reaction[]

  @@index([chatId, createdAt])
  @@index([senderId])
}

model Chat {
  id           String    @id
  type         String
  name         String
  avatarUrl    String?
  description  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  participants ChatParticipant[]

  @@index([updatedAt])
}

model ChatParticipant {
  chatId  String
  userId  String
  role    String  @default("MEMBER")
  joinedAt DateTime @default(now())

  chat    Chat    @relation(fields: [chatId], references: [id])

  @@id([chatId, userId])
  @@index([userId])
}

model Reaction {
  id         String    @id
  messageId  String
  userId     String
  emoji      String
  createdAt  DateTime  @default(now())

  message    Message   @relation(fields: [messageId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
}

model Call {
  id          String    @id
  chatId      String?
  callerId    String
  type        String
  status      String
  startedAt   DateTime?
  endedAt     DateTime?
  duration    Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([callerId])
  @@index([chatId])
}

model Story {
  id          String    @id
  userId      String
  type        String
  mediaUrl    String
  caption     String?
  viewersJson String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model WALCheckpoint {
  id Int @id @default(autoincrement())
}