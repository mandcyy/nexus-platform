<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0A0A0F"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nexus"
        android:textSize="42sp"
        android:textColor="#0066FF"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enterprise Communication Platform"
        android:textSize="14sp"
        android:textColor="#A0A0A8"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E1E24"
        android:padding="16dp"
        android:layout_marginTop="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API Connected"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/apiUrl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cloudflare Edge • Singapore"
            android:textSize="12sp"
            android:textColor="#00C853"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Get Started"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0066FF"
        android:layout_marginTop="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textSize="11sp"
        android:textColor="#555555"
        android:layout_marginTop="24dp" />

</LinearLayout>
